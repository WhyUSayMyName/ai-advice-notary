# Скопируйте этот файл в .env и заполните значения.
# .env находится в .gitignore и не должен попадать в git.

# URL RPC-узла (локальный hardhat node)
RPC_URL=http://127.0.0.1:8545

# Адрес контракта Notary (печатается при деплое: npx hardhat run scripts/deploy-notary.ts --network localhost)
NOTARY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Приватный ключ аккаунта, подписывающего транзакции.
# Для разработки — Account #0 из вывода `npx hardhat node`.
# НИКОГДА не используйте здесь ключ с реальными средствами.
NOTARY_PK=
